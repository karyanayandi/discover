---
import AdminSidebarHeader from "@/components/admin-sidebar-header.svelte"
import AdminUserMenu from "@/components/admin-user-menu.svelte"
import StoreInit from "@/components/store-init.svelte"
import { Toaster } from "@/components/ui/sonner"
import { getThemeScript } from "@/lib/theme"
import "@/styles/global.css"

interface Props {
  title?: string
}

const { title = "Admin — Discover" } = Astro.props
const pathname = Astro.url.pathname
const user = Astro.locals.user

const themeScript = getThemeScript()

const navItems = [
  { href: "/admin", label: "Dashboard", icon: "home" },
  { href: "/admin/pipeline", label: "Pipeline", icon: "pipeline" },
  { href: "/admin/feeds", label: "Feed Sources", icon: "rss" },
  { href: "/admin/categories", label: "Categories", icon: "tag" },
  { href: "/admin/clusters", label: "Clusters", icon: "layers" },
  { href: "/admin/assets", label: "Assets", icon: "image" },
  { href: "/admin/settings", label: "Settings", icon: "settings" },
]
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <script set:html={themeScript} is:inline />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <StoreInit
      user={user ? { id: user.id, name: user.name, email: user.email, image: user.image ?? null, role: user.role ?? null } : null}
      client:load
    />
    <div class="flex min-h-screen" id="admin-layout">
      <aside
        id="admin-sidebar"
        class="shrink-0 border-r border-border bg-muted/30 flex flex-col transition-all duration-300 ease-in-out -ml-64 w-64 lg:ml-0"
      >
        <div class="flex h-16 items-center gap-2 border-b border-border px-6">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary"
          >
            <path d="M12 2 2 7l10 5 10-5-10-5Z"></path>
            <path d="m2 17 10 5 10-5"></path>
            <path d="m2 12 10 5 10-5"></path>
          </svg>
          <span class="text-lg font-semibold">Discover</span>
          <span
            class="ml-auto rounded-md bg-primary/10 px-2 py-0.5 text-xs font-medium text-primary"
          >
            Admin
          </span>
        </div>

        <nav class="flex-1 space-y-1 px-3 py-4">
          {
            navItems.map((item) => {
              const isActive =
                item.href === "/admin"
                  ? pathname === "/admin"
                  : pathname.startsWith(item.href)
              return (
                <a
                  href={item.href}
                  class:list={[
                    "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors",
                    isActive
                      ? "bg-accent text-accent-foreground"
                      : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
                  ]}
                >
                  {item.icon === "home" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                      <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                  )}
                  {item.icon === "pipeline" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                  )}
                  {item.icon === "rss" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M4 11a9 9 0 0 1 9 9" />
                      <path d="M4 4a16 16 0 0 1 16 16" />
                      <circle cx="5" cy="19" r="1" />
                    </svg>
                  )}
                  {item.icon === "tag" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z" />
                      <path d="M7 7h.01" />
                    </svg>
                  )}
                  {item.icon === "layers" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polygon points="12 2 2 7 12 12 22 7 12 2" />
                      <polyline points="2 17 12 22 22 17" />
                      <polyline points="2 12 12 17 22 12" />
                    </svg>
                  )}
                  {item.icon === "settings" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
                      <circle cx="12" cy="12" r="3" />
                    </svg>
                  )}
                  {item.icon === "image" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                      <circle cx="9" cy="9" r="2" />
                      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                    </svg>
                  )}
                  {item.label}
                </a>
              )
            })
          }
        </nav>
      </aside>

      <div class="flex flex-1 flex-col">
        <header
          class="sticky top-0 z-40 flex h-16 items-center gap-4 border-b border-border bg-background/95 px-6 backdrop-blur supports-backdrop-filter:bg-background/60"
        >
          <div class="flex flex-1 items-center gap-4">
            <AdminSidebarHeader client:only="svelte" />
            <h1 class="text-lg font-semibold lg:hidden">Admin</h1>
          </div>
          <a
            href="/"
            class="text-sm text-muted-foreground transition-colors hover:text-foreground lg:hidden"
          >
            Back to site
          </a>
          <AdminUserMenu client:only="svelte" />
        </header>

        <main class="flex-1 p-6">
          <slot />
        </main>
      </div>
    </div>

    <Toaster client:load />

    <script>
      import { initElementSource } from "@/lib/element-source"

      if (typeof window !== "undefined") {
        console.log("[Element Source] Script loaded, initializing...")
        void initElementSource()
      }
    </script>
  </body>
</html>
