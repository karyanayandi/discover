---
import SiteHeader from "@/components/site-header.astro"
import { Toaster } from "@/components/ui/sonner"
import { getThemeScript } from "@/lib/theme"
import "@/styles/global.css"

interface Props {
  title?: string
  description?: string
  canonicalUrl?: string
  ogImage?: string
  ogType?: string
  noindex?: boolean
}

const {
  title = "Discover",
  description = "AI-curated news and insights",
  canonicalUrl,
  ogImage,
  ogType = "website",
  noindex = false,
} = Astro.props

const themeScript = getThemeScript()
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <script set:html={themeScript} is:inline />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <SiteHeader />
    <slot />
    <Toaster client:only="svelte" />

    <script>
      import { initElementSource } from "@/lib/element-source"

      if (typeof window !== "undefined") {
        console.log("[Element Source] Script loaded, initializing...")
        void initElementSource()
      }
    </script>
  </body>
</html>
