---
import AdminLayout from "@/layouts/admin-layout.astro"
import { db } from "@/lib/db/client"
import {
  articlesTable,
  categoriesTable,
  feedSourcesTable,
} from "@/lib/db/schemas"
import { count } from "drizzle-orm"

const [[articleCount], [categoryCount], [feedCount]] = await Promise.all([
  db.select({ count: count() }).from(articlesTable),
  db.select({ count: count() }).from(categoriesTable),
  db.select({ count: count() }).from(feedSourcesTable),
])

const stats = [
  {
    label: "Articles",
    value: articleCount?.count ?? 0,
    href: "/admin/feeds",
    icon: "article",
  },
  {
    label: "Categories",
    value: categoryCount?.count ?? 0,
    href: "/admin/categories",
    icon: "category",
  },
  {
    label: "Feed Sources",
    value: feedCount?.count ?? 0,
    href: "/admin/feeds",
    icon: "feed",
  },
]
---

<AdminLayout title="Dashboard — Admin">
  <div class="space-y-8">
    <div>
      <h2 class="text-2xl font-bold tracking-tight">Dashboard</h2>
      <p class="text-muted-foreground">
        Overview of your AI Discover platform.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        stats.map((stat) => (
          <a
            href={stat.href}
            class="rounded-xl border border-border bg-card p-6 transition-colors hover:bg-accent"
          >
            <p class="text-sm font-medium text-muted-foreground">
              {stat.label}
            </p>
            <p class="mt-2 text-3xl font-bold">{stat.value}</p>
          </a>
        ))
      }
    </div>

    <div class="rounded-xl border border-border bg-card p-6">
      <h3 class="mb-2 font-semibold">Quick Actions</h3>
      <div class="flex flex-wrap gap-3">
        <a
          href="/admin/pipeline"
          class="inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-medium transition-colors hover:bg-accent"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
          Pipeline
        </a>
        <a
          href="/admin/feeds"
          class="inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-medium transition-colors hover:bg-accent"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
          Manage Feeds
        </a>
        <a
          href="/admin/categories"
          class="inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-medium transition-colors hover:bg-accent"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"
            ></path>
            <path d="M7 7h.01"></path>
          </svg>
          Manage Categories
        </a>
        <a
          href="/admin/settings"
          class="inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-medium transition-colors hover:bg-accent"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43-.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
            ></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
          Settings
        </a>
      </div>
    </div>
  </div>
</AdminLayout>
