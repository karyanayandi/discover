---
import AdminLayout from "@/layouts/admin-layout.astro"
import { db } from "@/lib/db/client"
import { feedItemsTable, articlesTable } from "@/lib/db/schemas"
import { eq, sql } from "drizzle-orm"

// Get pipeline status
const statusCounts = await db
  .select({
    status: feedItemsTable.status,
    count: sql<number>`count(*)`.as("count"),
  })
  .from(feedItemsTable)
  .groupBy(feedItemsTable.status)

const statusMap = Object.fromEntries(
  statusCounts.map((row) => [row.status, row.count]),
)

const [articleResult] = await db
  .select({ count: sql<number>`count(*)`.as("count") })
  .from(articlesTable)

// Get recent articles
const recentArticles = await db
  .select({
    id: articlesTable.id,
    title: articlesTable.title,
    slug: articlesTable.slug,
    publishedAt: articlesTable.publishedAt,
  })
  .from(articlesTable)
  .orderBy(sql`${articlesTable.publishedAt} desc`)
  .limit(10)

// Get pending items
const pendingItems = await db
  .select({
    id: feedItemsTable.id,
    title: feedItemsTable.title,
    publishedAt: feedItemsTable.publishedAt,
    link: feedItemsTable.link,
  })
  .from(feedItemsTable)
  .where(eq(feedItemsTable.status, "pending"))
  .orderBy(sql`${feedItemsTable.publishedAt} desc`)
  .limit(20)

// Get processing items
const processingItems = await db
  .select({
    id: feedItemsTable.id,
    title: feedItemsTable.title,
    publishedAt: feedItemsTable.publishedAt,
    link: feedItemsTable.link,
  })
  .from(feedItemsTable)
  .where(eq(feedItemsTable.status, "processing"))
  .orderBy(sql`${feedItemsTable.publishedAt} desc`)
  .limit(10)

// Get failed items
const failedItems = await db
  .select({
    id: feedItemsTable.id,
    title: feedItemsTable.title,
    publishedAt: feedItemsTable.publishedAt,
    errorMessage: feedItemsTable.errorMessage,
  })
  .from(feedItemsTable)
  .where(eq(feedItemsTable.status, "failed"))
  .orderBy(sql`${feedItemsTable.publishedAt} desc`)
  .limit(10)

const pipelineStats = [
  {
    label: "Pending",
    value: statusMap.pending ?? 0,
    color: "yellow",
    description: "Items waiting to be processed",
  },
  {
    label: "Processing",
    value: statusMap.processing ?? 0,
    color: "blue",
    description: "Currently being processed",
  },
  {
    label: "Processed",
    value: statusMap.processed ?? 0,
    color: "green",
    description: "Successfully converted to articles",
  },
  {
    label: "Failed",
    value: statusMap.failed ?? 0,
    color: "red",
    description: "Failed during processing",
  },
]
---

<AdminLayout title="Pipeline — Admin">
  <div class="space-y-8">
    <div>
      <h2 class="text-2xl font-bold tracking-tight">Pipeline</h2>
      <p class="text-muted-foreground">
        Manage feed processing and article generation
      </p>
    </div>

    <!-- Status Overview -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        pipelineStats.map((stat) => (
          <div
            class={`rounded-xl border border-border bg-card p-6 ${
              stat.color === "yellow"
                ? "border-yellow-200 dark:border-yellow-800"
                : stat.color === "blue"
                  ? "border-blue-200 dark:border-blue-800"
                  : stat.color === "green"
                    ? "border-green-200 dark:border-green-800"
                    : "border-red-200 dark:border-red-800"
            }`}
          >
            <p class="text-sm font-medium text-muted-foreground">
              {stat.label}
            </p>
            <p
              class={`mt-2 text-3xl font-bold ${
                stat.color === "yellow"
                  ? "text-yellow-600 dark:text-yellow-400"
                  : stat.color === "blue"
                    ? "text-blue-600 dark:text-blue-400"
                    : stat.color === "green"
                      ? "text-green-600 dark:text-green-400"
                      : "text-red-600 dark:text-red-400"
              }`}
            >
              {stat.value}
            </p>
            <p class="mt-1 text-xs text-muted-foreground">
              {stat.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Actions -->
    <div class="flex flex-wrap gap-4">
      <button
        id="run-pipeline-btn"
        class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
        Run Full Pipeline
      </button>

      <button
        id="reset-pipeline-btn"
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-6 py-3 text-sm font-medium transition-colors hover:bg-accent"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 12"></path>
          <path d="M3 3v9h9"></path>
        </svg>
        Reset Stuck Items
      </button>

      <button
        id="reset-failed-btn"
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-6 py-3 text-sm font-medium transition-colors hover:bg-accent"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 12"></path>
          <path d="M3 3v9h9"></path>
        </svg>
        Reset Failed Items
      </button>

      <a
        href="/admin/feeds"
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-6 py-3 text-sm font-medium transition-colors hover:bg-accent"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </svg>
        Manage Feed Sources
      </a>
    </div>

    <!-- Pending Items Section -->
    <div class="rounded-xl border border-border bg-card">
      <div class="border-b border-border p-6">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-semibold">Pending Items</h3>
            <p class="text-sm text-muted-foreground">
              {pendingItems.length} items waiting to be processed
            </p>
          </div>
          <span class="rounded-full bg-yellow-100 px-3 py-1 text-sm font-medium text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
            {statusMap.pending ?? 0}
          </span>
        </div>
      </div>
      
      {
        pendingItems.length > 0 ? (
          <div class="divide-y divide-border">
            {pendingItems.map((item) => (
              <div class="flex items-center justify-between gap-4 p-4">
                <div class="min-w-0 flex-1">
                  <p class="truncate font-medium">
                    {item.title ?? "Untitled"}
                  </p>
                  <div class="mt-1 flex items-center gap-3 text-xs text-muted-foreground">
                    <span>
                      {item.publishedAt
                        ? new Date(item.publishedAt).toLocaleDateString()
                        : "No date"}
                    </span>
                    {item.link && (
                      <a 
                        href={item.link} 
                        target="_blank" 
                        rel="noopener"
                        class="hover:text-foreground"
                      >
                        View Source →
                      </a>
                    )}
                  </div>
                </div>
                <button
                  class="generate-btn inline-flex items-center gap-2 rounded-md border border-border bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-accent"
                  data-feed-id={item.id}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </svg>
                  Generate Article
                </button>
              </div>
            ))}
          </div>
        ) : (
          <div class="p-8 text-center text-muted-foreground">
            <p>No pending items</p>
            <p class="text-sm">All feed items have been processed</p>
          </div>
        )
      }
    </div>

    <!-- Processing Items Section -->
    {
      processingItems.length > 0 && (
        <div class="rounded-xl border border-border bg-card">
          <div class="border-b border-border p-6">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-semibold">Processing</h3>
                <p class="text-sm text-muted-foreground">
                  Currently being processed
                </p>
              </div>
              <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                {processingItems.length}
              </span>
            </div>
          </div>
          <div class="divide-y divide-border">
            {processingItems.map((item) => (
              <div class="flex items-center gap-3 p-4">
                <svg
                  class="animate-spin text-blue-500"
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M21 12a9 9 0 1 1-6.219-8.56" />
                </svg>
                <div class="min-w-0 flex-1">
                  <p class="truncate font-medium">
                    {item.title ?? "Untitled"}
                  </p>
                  <p class="text-xs text-muted-foreground">
                    Started processing...
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- Failed Items Section -->
    {
      failedItems.length > 0 && (
        <div class="rounded-xl border border-border bg-card">
          <div class="border-b border-border p-6">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-lg font-semibold">Failed Items</h3>
                <p class="text-sm text-muted-foreground">
                  Items that failed during processing
                </p>
              </div>
              <span class="rounded-full bg-red-100 px-3 py-1 text-sm font-medium text-red-800 dark:bg-red-900 dark:text-red-200">
                {failedItems.length}
              </span>
            </div>
          </div>
          <div class="divide-y divide-border">
            {failedItems.map((item) => (
              <div class="p-4">
                <p class="truncate font-medium text-red-600 dark:text-red-400">
                  {item.title ?? "Untitled"}
                </p>
                {item.errorMessage && (
                  <p class="mt-1 text-xs text-muted-foreground">
                    Error: {item.errorMessage}
                  </p>
                )}
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- Recent Articles Section -->
    <div class="rounded-xl border border-border bg-card">
      <div class="border-b border-border p-6">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-lg font-semibold">Recent Articles</h3>
            <p class="text-sm text-muted-foreground">
              Latest {recentArticles.length} articles generated
            </p>
          </div>
          <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800 dark:bg-green-900 dark:text-green-200">
            {articleResult?.count ?? 0} total
          </span>
        </div>
      </div>
      
      {
        recentArticles.length > 0 ? (
          <div class="divide-y divide-border">
            {recentArticles.map((article) => (
              <a
                href={`/articles/${article.slug}`}
                class="flex items-center justify-between gap-4 p-4 transition-colors hover:bg-accent"
              >
                <div class="min-w-0 flex-1">
                  <p class="truncate font-medium">
                    {article.title ?? "Untitled"}
                  </p>
                  <p class="mt-1 text-xs text-muted-foreground">
                    {article.publishedAt
                      ? new Date(article.publishedAt).toLocaleDateString()
                      : "No date"}
                  </p>
                </div>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-muted-foreground"
                >
                  <path d="M18 13v6a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14l4-4h5z" />
                  <path d="m9 13 2 2 4-4" />
                </svg>
              </a>
            ))}
          </div>
        ) : (
          <div class="p-8 text-center text-muted-foreground">
            <p>No articles yet</p>
            <p class="text-sm">Run the pipeline to generate articles</p>
          </div>
        )
      }
    </div>
  </div>

  <script>
    // Run pipeline button
    document
      .getElementById("run-pipeline-btn")
      ?.addEventListener("click", async () => {
        const btn = document.getElementById(
          "run-pipeline-btn",
        ) as HTMLButtonElement | null
        if (!btn) return

        btn.disabled = true
        btn.innerHTML = `
          <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
          </svg>
          Running Pipeline...
        `

        try {
          const response = await fetch("/api/internal/pipeline/run", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
          })

          const result = await response.json()

          if (result.success) {
            alert(
              `Pipeline completed successfully!\n\nFeeds processed: ${result.result.feedsProcessed}\nClusters found: ${result.result.clustersFound}\nArticles created: ${result.result.articlesCreated}`,
            )
            window.location.reload()
          } else {
            alert(`Pipeline failed: ${result.error}`)
          }
        } catch (error) {
          alert(`Error: ${error}`)
        } finally {
          btn.disabled = false
          btn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
            Run Full Pipeline
          `
        }
      })

    // Reset pipeline button
    document
      .getElementById("reset-pipeline-btn")
      ?.addEventListener("click", async () => {
        const btn = document.getElementById(
          "reset-pipeline-btn",
        ) as HTMLButtonElement | null
        if (!btn) return

        if (!confirm("Reset all stuck 'processing' items back to 'pending'?")) {
          return
        }

        btn.disabled = true
        const originalText = btn.innerHTML
        btn.innerHTML = `
          <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
          </svg>
          Resetting...
        `

        try {
          const response = await fetch("/api/admin/pipeline/reset", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
          })

          const result = await response.json()

          if (result.success) {
            alert(result.message)
            window.location.reload()
          } else {
            alert(`Reset failed: ${result.error}`)
            btn.disabled = false
            btn.innerHTML = originalText
          }
        } catch (error) {
          alert(`Error: ${error}`)
          btn.disabled = false
          btn.innerHTML = originalText
        }
      })

    // Reset failed items button
    document
      .getElementById("reset-failed-btn")
      ?.addEventListener("click", async () => {
        const btn = document.getElementById(
          "reset-failed-btn",
        ) as HTMLButtonElement | null
        if (!btn) return

        if (!confirm("Reset all 'failed' items back to 'pending'?")) {
          return
        }

        btn.disabled = true
        const originalText = btn.innerHTML
        btn.innerHTML = `
          <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
          </svg>
          Resetting...
        `

        try {
          const response = await fetch("/api/admin/pipeline/reset", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ type: "failed" }),
          })

          const result = await response.json()

          if (result.success) {
            alert(result.message)
            window.location.reload()
          } else {
            alert(`Reset failed: ${result.error}`)
            btn.disabled = false
            btn.innerHTML = originalText
          }
        } catch (error) {
          alert(`Error: ${error}`)
          btn.disabled = false
          btn.innerHTML = originalText
        }
      })

    // Generate individual article buttons
    document.querySelectorAll(".generate-btn").forEach((el) => {
      const btn = el as HTMLButtonElement
      btn.addEventListener("click", async () => {
        const feedId = btn.getAttribute("data-feed-id")
        if (!feedId) return

        btn.disabled = true
        const originalText = btn.innerHTML
        btn.innerHTML = `
          <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
          </svg>
          Starting...
        `

        try {
          const response = await fetch("/api/admin/pipeline/generate", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ feedItemId: feedId }),
          })

          const result = await response.json()

          if (result.success) {
            alert(`${result.message}\n\nThe page will refresh in 3 seconds to show progress...`)
            // Wait a bit then reload to show processing state
            setTimeout(() => {
              window.location.reload()
            }, 3000)
          } else {
            alert(`Failed: ${result.error}`)
            btn.disabled = false
            btn.innerHTML = originalText
          }
        } catch (error) {
          alert(`Error: ${error}`)
          btn.disabled = false
          btn.innerHTML = originalText
        }
      })
    })
  </script>
</AdminLayout>
