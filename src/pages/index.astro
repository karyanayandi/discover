---
import { count, desc, eq } from "drizzle-orm"
import ArticleFeed from "@/components/article-feed.svelte"
import CategorySidebar from "@/components/category-sidebar.svelte"
import StoreInit from "@/components/store-init.svelte"
import Layout from "@/layouts/layout.astro"
import { db } from "@/lib/db/client"
import { getSavedSlugsForUser } from "@/lib/db/queries"
import {
  articleCategoriesTable,
  articlesTable,
  categoriesTable,
} from "@/lib/db/schemas"

const categorySlug = Astro.url.searchParams.get("category") ?? ""

if (categorySlug) {
  return Astro.redirect(`/category/${categorySlug}`)
}

const limit = 20

const user = Astro.locals.user
const savedSlugs = user ? await getSavedSlugsForUser(user.id) : []

const topCategories = await db
  .select({
    id: categoriesTable.id,
    slug: categoriesTable.slug,
    name: categoriesTable.name,
    color: categoriesTable.color,
    articleCount: count(articleCategoriesTable.articleId),
  })
  .from(categoriesTable)
  .leftJoin(
    articleCategoriesTable,
    eq(categoriesTable.id, articleCategoriesTable.categoryId),
  )
  .groupBy(categoriesTable.id)
  .orderBy(desc(count(articleCategoriesTable.articleId)))
  .limit(10)

const where = eq(articlesTable.status, "published")

const [articles, [totalRow]] = await Promise.all([
  db.query.articlesTable.findMany({
    where,
    orderBy: [desc(articlesTable.publishedAt)],
    limit,
    columns: {
      id: true,
      slug: true,
      title: true,
      summary: true,
      thumbnailUrl: true,
      sourceCount: true,
      readingTimeMinutes: true,
      publishedAt: true,
    },
  }),
  db.select({ count: count() }).from(articlesTable).where(where),
])

const total = totalRow?.count ?? 0
const canonicalUrl = Astro.url.origin
---

<Layout title="Discover - AI-Curated Insights" canonicalUrl={canonicalUrl}>
  <StoreInit
    user={user ? { id: user.id, name: user.name, email: user.email, image: user.image ?? null, role: user.role ?? null } : null}
    {savedSlugs}
    client:load
  />
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex gap-8">
      <aside class="hidden w-56 shrink-0 lg:block">
        <CategorySidebar
          categories={topCategories}
          showExploreLink={true}
          client:load
        />
      </aside>

      <main class="min-w-0 flex-1">
        <ArticleFeed
          initialArticles={articles}
          initialTotal={total}
          pageSize={limit}
          client:load
        />
      </main>
    </div>
  </div>
</Layout>
