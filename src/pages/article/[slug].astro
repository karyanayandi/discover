---
import { and, desc, eq, ne } from "drizzle-orm"
import CitationList from "@/components/citation-list.svelte"
import RelatedInsights from "@/components/related-insights.svelte"
import SaveButton from "@/components/save-button.svelte"
import ShareButton from "@/components/share-button.svelte"
import StoreInit from "@/components/store-init.svelte"
import Badge from "@/components/ui/badge/badge.svelte"
import Separator from "@/components/ui/separator/separator.svelte"
import Layout from "@/layouts/layout.astro"
import { db } from "@/lib/db/client"
import { getSavedSlugsForUser } from "@/lib/db/queries"
import {
  articleCategoriesTable,
  articleSectionsTable,
  articlesTable,
  assetsTable,
  categoriesTable,
  citationsTable,
} from "@/lib/db/schemas"
import type { SelectArticleSection } from "@/lib/db/schemas/article-sections"
import { logger } from "@/lib/logger"
import { normalizeImageUrl } from "@/lib/utils/image-url"

const { slug } = Astro.params
if (!slug) return Astro.redirect("/")

const article = await db.query.articlesTable.findFirst({
  where: eq(articlesTable.slug, slug),
})

if (!article) return Astro.redirect("/")

const normalizedThumbnailUrl = normalizeImageUrl(article.thumbnailUrl)

if (normalizedThumbnailUrl && !article.thumbnailAssetId) {
  const url = new URL(normalizedThumbnailUrl, Astro.url.origin)
  const filename = url.pathname.split("/").pop() ?? "thumbnail"
  db.insert(assetsTable)
    .values({
      filename,
      originalName: filename,
      type: "images",
      size: 0,
      url: normalizedThumbnailUrl,
    })
    .returning({ id: assetsTable.id })
    .then(([row]) => {
      if (row) {
        return db
          .update(articlesTable)
          .set({ thumbnailAssetId: row.id })
          .where(eq(articlesTable.id, article.id))
      }
    })
    .catch((err: unknown) => {
      logger.warn(
        { err, articleId: article.id },
        "Lazy thumbnail registration failed",
      )
    })
}

const [sections, citations, categoryLinks] = await Promise.all([
  db.query.articleSectionsTable.findMany({
    where: eq(articleSectionsTable.articleId, article.id),
    orderBy: [articleSectionsTable.sortOrder],
  }),
  db.query.citationsTable.findMany({
    where: eq(citationsTable.articleId, article.id),
    orderBy: [citationsTable.sortOrder],
  }),
  db
    .select({ slug: categoriesTable.slug, name: categoriesTable.name })
    .from(articleCategoriesTable)
    .innerJoin(
      categoriesTable,
      eq(articleCategoriesTable.categoryId, categoriesTable.id),
    )
    .where(eq(articleCategoriesTable.articleId, article.id)),
])

const user = Astro.locals.user
const savedSlugs = user ? await getSavedSlugsForUser(user.id) : []

const relatedArticles = await db.query.articlesTable.findMany({
  where: and(
    eq(articlesTable.status, "published"),
    ne(articlesTable.id, article.id),
  ),
  orderBy: [desc(articlesTable.publishedAt)],
  limit: 3,
  columns: {
    id: true,
    slug: true,
    title: true,
    summary: true,
    thumbnailUrl: true,
    sourceCount: true,
    readingTimeMinutes: true,
    publishedAt: true,
  },
})

const articleUrl = `${Astro.url.origin}/article/${slug}`
const ogImageUrl = normalizedThumbnailUrl
  ? normalizedThumbnailUrl.startsWith("http")
    ? normalizedThumbnailUrl
    : `${Astro.url.origin}${normalizedThumbnailUrl}`
  : undefined
---

<Layout
  title={`${article.title} - Discover`}
  description={article.summary}
  canonicalUrl={articleUrl}
  ogImage={ogImageUrl}
  ogType="article"
>
  <StoreInit
    user={user ? { id: user.id, name: user.name, email: user.email, image: user.image ?? null, role: user.role ?? null } : null}
    {savedSlugs}
    client:load
  />
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex items-center justify-between">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to Feed
      </a>
      <div class="flex items-center gap-2">
        <ShareButton title={article.title} url={articleUrl} client:load />
        <SaveButton slug={slug} client:load />
      </div>
    </div>

    <article>
      <header class="mb-8">
        <div class="mb-4 flex flex-wrap gap-2">
          {categoryLinks.map((cat: { slug: string; name: string }) => (
            <a href={`/category/${cat.slug}`}>
              <Badge variant="secondary">{cat.name}</Badge>
            </a>
          ))}
        </div>

        <h1 class="text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl">
          {article.title}
        </h1>

        <div class="mt-6 flex flex-wrap items-center gap-6 text-sm text-muted-foreground">
          <div class="flex items-center gap-2">
            <div class="flex h-7 w-7 items-center justify-center rounded-full bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
            </div>
            <span>AI Discover</span>
          </div>
          {article.publishedAt && (
            <div class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              <time datetime={article.publishedAt.toISOString()}>
                {article.publishedAt.toLocaleDateString("en-US", {
                  month: "long",
                  day: "numeric",
                  year: "numeric",
                })}
              </time>
            </div>
          )}
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{article.readingTimeMinutes} min read</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
            <span>{article.sourceCount} sources</span>
          </div>
        </div>
      </header>

      <div class="mb-8 rounded-xl border border-border bg-muted/50 p-6">
        <div class="mb-3 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
            Executive Summary
          </h2>
        </div>
        <p class="leading-relaxed text-foreground/90">
          {article.summary}
        </p>
      </div>

      {normalizedThumbnailUrl && (
        <img
          src={normalizedThumbnailUrl}
          alt={`Cover image for ${article.title}`}
          class="mb-8 aspect-video w-full rounded-xl object-cover"
          loading="eager"
        />
      )}

      <div class="prose prose-neutral dark:prose-invert max-w-none">
        {sections.map((section: SelectArticleSection) => (
          <section>
            <h2>{section.heading}</h2>
            <Fragment set:html={section.body} />
          </section>
        ))}

        {sections.length === 0 && (
          <Fragment set:html={article.content} />
        )}
      </div>
    </article>

    {citations.length > 0 && (
      <>
        <Separator class="my-10" />
        <CitationList {citations} client:load />
      </>
    )}

    {relatedArticles.length > 0 && (
      <>
        <Separator class="my-10" />
        <RelatedInsights articles={relatedArticles} client:load />
      </>
    )}
  </div>
</Layout>
