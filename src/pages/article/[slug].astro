---
import { and, desc, eq, ne } from "drizzle-orm"
import CitationList from "@/components/citation-list.svelte"
import RelatedInsights from "@/components/related-insights.svelte"
import SaveButton from "@/components/save-button.svelte"
import ShareButton from "@/components/share-button.svelte"
import StoreInit from "@/components/store-init.svelte"
import Badge from "@/components/ui/badge/badge.svelte"
import Separator from "@/components/ui/separator/separator.svelte"
import Layout from "@/layouts/layout.astro"
import { db } from "@/lib/db/client"
import { getSavedSlugsForUser } from "@/lib/db/queries"
import {
  articleCategoriesTable,
  articleSectionsTable,
  articlesTable,
  assetsTable,
  categoriesTable,
  citationsTable,
} from "@/lib/db/schemas"
import type { SelectArticleSection } from "@/lib/db/schemas/article-sections"
import { logger } from "@/lib/logger"

const { slug } = Astro.params
if (!slug) return Astro.redirect("/")

const article = await db.query.articlesTable.findFirst({
  where: eq(articlesTable.slug, slug),
})

if (!article) return Astro.redirect("/")

if (article.thumbnailUrl && !article.thumbnailAssetId) {
  const url = new URL(article.thumbnailUrl, Astro.url.origin)
  const filename = url.pathname.split("/").pop() ?? "thumbnail"
  db.insert(assetsTable)
    .values({
      filename,
      originalName: filename,
      type: "images",
      size: 0,
      url: article.thumbnailUrl,
    })
    .returning({ id: assetsTable.id })
    .then(([row]) => {
      if (row) {
        return db
          .update(articlesTable)
          .set({ thumbnailAssetId: row.id })
          .where(eq(articlesTable.id, article.id))
      }
    })
    .catch((err: unknown) => {
      logger.warn(
        { err, articleId: article.id },
        "Lazy thumbnail registration failed",
      )
    })
}

const [sections, citations, categoryLinks] = await Promise.all([
  db.query.articleSectionsTable.findMany({
    where: eq(articleSectionsTable.articleId, article.id),
    orderBy: [articleSectionsTable.sortOrder],
  }),
  db.query.citationsTable.findMany({
    where: eq(citationsTable.articleId, article.id),
    orderBy: [citationsTable.sortOrder],
  }),
  db
    .select({ slug: categoriesTable.slug, name: categoriesTable.name })
    .from(articleCategoriesTable)
    .innerJoin(
      categoriesTable,
      eq(articleCategoriesTable.categoryId, categoriesTable.id),
    )
    .where(eq(articleCategoriesTable.articleId, article.id)),
])

const user = Astro.locals.user
const savedSlugs = user ? await getSavedSlugsForUser(user.id) : []

const relatedArticles = await db.query.articlesTable.findMany({
  where: and(
    eq(articlesTable.status, "published"),
    ne(articlesTable.id, article.id),
  ),
  orderBy: [desc(articlesTable.publishedAt)],
  limit: 3,
  columns: {
    id: true,
    slug: true,
    title: true,
    summary: true,
    thumbnailUrl: true,
    sourceCount: true,
    readingTimeMinutes: true,
    publishedAt: true,
  },
})

const articleUrl = `${Astro.url.origin}/article/${slug}`
---

<Layout title={`${article.title} - Discover`} description={article.summary}>
  <StoreInit
    user={user ? { id: user.id, name: user.name, email: user.email, image: user.image ?? null, role: user.role ?? null } : null}
    {savedSlugs}
    client:load
  />
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
    <nav class="mb-6">
      <a
        href="/"
        class="text-sm text-muted-foreground hover:text-foreground"
      >
        &larr; Back to feed
      </a>
    </nav>

    <article>
      <header class="mb-6">
        <div class="mb-3 flex flex-wrap gap-2">
          {categoryLinks.map((cat: { slug: string; name: string }) => (
            <Badge variant="secondary">{cat.name}</Badge>
          ))}
        </div>

        <h1 class="text-3xl font-bold tracking-tight text-foreground">
          {article.title}
        </h1>

        <p class="mt-3 text-lg text-muted-foreground">
          {article.summary}
        </p>

        <div class="mt-4 flex items-center gap-4">
          <span class="text-sm text-muted-foreground">
            {article.sourceCount} sources
          </span>
          <span class="text-sm text-muted-foreground">
            {article.readingTimeMinutes} min read
          </span>
          {article.publishedAt && (
            <time
              datetime={article.publishedAt.toISOString()}
              class="text-sm text-muted-foreground"
            >
              {article.publishedAt.toLocaleDateString("en-US", {
                month: "long",
                day: "numeric",
                year: "numeric",
              })}
            </time>
          )}
        </div>

        <div class="mt-4 flex gap-2">
          <SaveButton slug={slug} client:load />
          <ShareButton title={article.title} url={articleUrl} client:load />
        </div>
      </header>

      {article.thumbnailUrl && (
        <img
          src={article.thumbnailUrl}
          alt=""
          class="mb-8 w-full rounded-xl object-cover"
          loading="eager"
        />
      )}

      <Separator />

      <div class="prose prose-neutral dark:prose-invert mt-8 max-w-none">
        {sections.map((section: SelectArticleSection) => (
          <section>
            <h2>{section.heading}</h2>
            <Fragment set:html={section.body} />
          </section>
        ))}

        {sections.length === 0 && (
          <Fragment set:html={article.content} />
        )}
      </div>
    </article>

    <Separator class="my-8" />

    <div class="grid gap-8 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <CitationList {citations} client:load />
      </div>
      <div>
        <RelatedInsights articles={relatedArticles} client:load />
      </div>
    </div>
  </div>
</Layout>
