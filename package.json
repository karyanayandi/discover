{
  "name": "discover",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "check": "bun run format:check && bun run lint && bun run typecheck",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format:check": "biome check .",
    "format:write": "biome format . --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --fix",
    "fix": "bun run format:write && bun run lint:fix",
    "typecheck": "astro check && svelte-check",
    "db:migrate": "bun run drizzle-kit migrate",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@astrojs/svelte": "^7.2.5",
    "@lucide/astro": "^0.577.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/svelte-form": "^1.28.4",
    "@tanstack/svelte-query": "^6.1.0",
    "astro": "^5.17.1",
    "better-result": "^2.7.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "ioredis": "^5.10.0",
    "nanostores": "^1.1.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "svelte": "^5.53.7",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/ts-plugin": "1.10.6",
    "@biomejs/biome": "2.4.6",
    "@lucide/svelte": "^0.561.0",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^25.3.5",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.9",
    "lefthook": "^2.1.3",
    "mode-watcher": "^1.1.0",
    "pino-pretty": "^13.1.3",
    "svelte-check": "^4.4.5",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  }
}
